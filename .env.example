# Optional: OpenAI für Konzept-Generierung (JSON). Ohne Key: deterministischer Fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: JSON-Datei für gemeinsamen Store über Serverless-Instanzen (z. B. /tmp/pitchdeck-store.json auf Vercel).
# Ohne diese Variable: reiner In-Memory pro Instanz (lokal ein Prozess = ok; Vercel = Daten wirken „verloren“).
PITCHDECK_STORE_PATH=

# Später: ElevenLabs, Datenbank, Object Storage (siehe docs/technische-codex-roadmap.md)
