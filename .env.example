# Prisma / SQLite (App: apps/web) – nach Klonen: cd apps/web && npx prisma db push
# Relativ zum Ordner apps/web/prisma/ (Schema-Ort)
DATABASE_URL="file:./dev.db"

# Optional: OpenAI für Konzept-Generierung (JSON). Ohne Key: deterministischer Fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

