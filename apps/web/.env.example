# Kopiere nach apps/web/.env
#
# --- Option A: PostgreSQL lokal (Docker im Repo-Root) ---
#   docker compose up -d
#   danach: cd apps/web && npx prisma db push && npm run db:seed
DATABASE_URL="postgresql://pitchdeck:pitchdeck@localhost:5432/pitchdeck"
#
# --- Option B: Neon / Supabase / Railway (Production & Vercel) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
#
# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
